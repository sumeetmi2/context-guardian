{
  "name": "context-guardian",
  "description": "Monitors Claude Code context/token pressure and generates durable session handovers before context becomes constrained. Phase 1: visibility + manual checkpointing (no automatic compaction or rollover).",
  "version": "0.2.1",
  "author": {
    "name": "Context Guardian"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/bin/cg.py\" hook session-start",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/bin/cg.py\" hook user-prompt-submit",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/bin/cg.py\" hook pre-compact",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/bin/cg.py\" hook stop",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/bin/cg.py\" hook session-end",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
